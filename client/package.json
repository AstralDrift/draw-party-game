    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  }
}
